{
  "name": "sanghel-playbook",
  "version": "0.1.0",
  "description": "CLI/TUI para instalar patrones y scaffoldear proyectos desde el sanghel-playbook",
  "type": "module",
  "bin": {
    "sanghel-playbook": "./dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
